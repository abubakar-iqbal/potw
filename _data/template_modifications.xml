<?xml version="1.0" encoding="utf-8"?>
<template_modifications>
  <modification type="public" template="member_macros" modification_key="cb_potw_member_stat_wins" description="Show POTW win count on member profile stats" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<!--[XF:stat_pairs:above_trophies]-->]]></find>
    <replace><![CDATA[<xf:if is="$user.cb_potw_count">
		<dl class="pairs pairs--rows pairs--rows--centered">
			<dt>{{ phrase('cb_potw_wins') }}</dt>
			<dd>{$user.cb_potw_count|number}</dd>
		</dl>
	</xf:if>
	$0]]></replace>
  </modification>
  <modification type="public" template="message_macros" modification_key="cb_potw_postbit_wins" description="Show POTW win count in message user info (postbit)" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<xf:if is="$extras.solutions AND $user.question_solution_count">]]></find>
    <replace><![CDATA[<xf:if is="$user.cb_potw_count">
						<dl class="pairs pairs--justified">
							<dt>{{ phrase('cb_potw_wins') }}</dt>
							<dd>{$user.cb_potw_count|number}</dd>
						</dl>
					</xf:if>
					$0]]></replace>
  </modification>
  <modification type="public" template="post_macros" modification_key="cb_potw_promote_link" description="Add &quot;Promote POTW&quot; link to the post action bar" execution_order="10" enabled="1" action="str_replace">
    <find><![CDATA[<xf:react content="{$post}" link="posts/react" list="< .js-post | .js-reactionsList" />]]></find>
    <replace><![CDATA[$0

			<xf:if is="$post.canPromoteToPotw()">
				<a href="{{ link('posts/potw-promote', $post) }}"
					class="actionBar-action actionBar-action--potwPromote"
					data-xf-click="overlay"
					rel="nofollow">{{ $post.isPotwPromoted() ? phrase('cb_potw_demote') : phrase('cb_potw_promote') }}</a>
			</xf:if>]]></replace>
  </modification>
</template_modifications>
