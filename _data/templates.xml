                    {{ phrase('cb_most_liked_posts_week') }} {{ date($weekKey) }}
                </h4>

                <div class="block-body">
                    <xf:foreach loop="$allPosts" value="$post">
                        <xf:if is="{{ in_array($post.post_id, $postIds) }}">
